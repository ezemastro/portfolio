---
import TechBadge from "@/components/TechBadge";
import ImageCarousel from "@/components/ImageCarousel";
import AskAIButton from "@/components/AskAIButton";
import type { Project } from "@/constants/projects";

interface Props {
  project: Project;
  slideCount?: number;
  /** Max tilt rotation in degrees — smaller for visually larger cards. */
  tiltMax?: number;
}

const { project, slideCount = 2, tiltMax = 2.5 } = Astro.props;
---

<article
  data-tilt
  data-tilt-max={tiltMax}
  class="group border-theme-200 bg-theme-50/90 hover:border-theme-400 [transform-style:preserve-3d] [will-change:transform] flex h-full flex-col rounded-sm border p-6 shadow-sm transition-[box-shadow,border-color] duration-300 hover:shadow-[0_8px_30px_-8px] hover:shadow-theme-400/30"
>
  {
    project.links?.repo && (
      <div class="flex justify-end">
        <a
          href={project.links.repo}
          target="_blank"
          rel="noopener noreferrer"
          class="text-theme-400 hover:text-theme-600 inline-block transition-all duration-200 ease-[cubic-bezier(0.34,1.56,0.64,1)] hover:scale-125 hover:rotate-12 active:scale-90"
          aria-label="Ver repositorio"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-5"
          >
            <path d="M9 18l6-6-6-6" />
          </svg>
        </a>
      </div>
    )
  }

  <h3 class="font-martian-mono text-theme-800 mt-3 text-xl font-semibold">
    {project.title}
  </h3>

  <p class="text-theme-600 mt-2 text-sm leading-relaxed">
    {project.description}
  </p>

  <!-- Image carousel -->
  <div class="mt-4">
    <ImageCarousel count={slideCount} client:load />
  </div>

  <!-- Tech badges -->
  <div class="mt-4 flex flex-wrap gap-2">
    {
      project.techStack.map((tech) => (
        <TechBadge
          name={tech.name}
          icon={tech.icon}
          explanation={tech.explanation}
          client:load
        />
      ))
    }
  </div>

  <!-- Long description — always visible -->
  {
    project.longDescription && (
      <p class="text-theme-600 mt-4 text-sm leading-relaxed">
        {project.longDescription}
      </p>
    )
  }

  <!-- Links + AI button -->
  <div class="mt-auto flex flex-wrap items-center gap-3 pt-4">
    {
      project.links?.demo && (
        <a
          href={project.links.demo}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-theme-400 hover:bg-theme-500 inline-flex items-center gap-1.5 rounded-sm px-3 py-1 text-xs font-medium text-white transition-all duration-250 ease-[cubic-bezier(0.34,1.56,0.64,1)] hover:scale-110 active:scale-90"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-3.5"
          >
            <>
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
            </>
          </svg>
          Demo
        </a>
      )
    }
    {
      project.links?.playStore && (
        <a
          href={project.links.playStore}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-theme-200 text-theme-700 hover:bg-theme-300 inline-flex items-center gap-1.5 rounded-sm px-3 py-1 text-xs font-medium transition-all duration-250 ease-[cubic-bezier(0.34,1.56,0.64,1)] hover:scale-110 active:scale-90"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-3.5"
          >
            <polygon points="5 3 19 12 5 21 5 3" />
          </svg>
          Play Store
        </a>
      )
    }

    <AskAIButton projectTitle={project.title} client:load />
  </div>
</article>
