---
import Content from "./Content";
import Tab from "./Tab";
---

<div
  id="mini-terminal"
  class="mini-terminal bg-theme-800 border-theme-700 relative flex h-72 w-full max-w-xl shrink-0 flex-col rounded-sm border sm:h-80 md:w-[min(36rem,45vw)]"
>
  <div class="bg-theme-700 flex h-9 w-full rounded-t-sm">
    <Tab client:load client:only />
  </div>
  <div class="flex w-full grow overflow-hidden px-4 py-2">
    <Content client:load client:only />
  </div>
</div>

<style>
  .mini-terminal {
    transform-style: preserve-3d;
    will-change: transform;
  }
</style>

<script>
  import { attachTilt } from "@/lib/tilt";

  const card = document.getElementById("mini-terminal");
  if (!card) throw new Error("mini-terminal not found");

  // Only react while the pointer is actually over the terminal — an
  // "ambient" (page-wide) tilt reads as the card moving on its own.
  attachTilt(card, { mode: "hover", maxTilt: 8, peak: 260, lerp: 0.15 });
</script>
