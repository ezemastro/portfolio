---
import { getCollection } from "astro:content";
import AIChat from "@/components/AIChat";

const entries = await getCollection("aiContext");
const systemPrompt = entries.map((e) => e.body).join("\n\n");
---

<section
  id="ia"
  class="container-page relative scroll-mt-16 py-16 md:py-24"
>
  <div
    class="glow-blob absolute top-0 right-0 -z-1 h-80 w-80"
    aria-hidden="true"
  >
  </div>
  <h2
    data-reveal="left"
    class="font-martian-mono text-theme-800 text-3xl font-semibold md:text-4xl"
  >
    Preguntame algo
  </h2>
  <div
    data-reveal="bar"
    style="transition-delay: 150ms"
    class="bg-theme-400 mt-2 mb-10 h-1 w-16 rounded-sm"
    aria-hidden="true"
  >
  </div>
  <div data-reveal="scale" style="transition-delay: 160ms">
    <AIChat client:load systemPrompt={systemPrompt} />
  </div>
</section>
