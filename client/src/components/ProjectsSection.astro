---
import ProjectCard from "@/components/ProjectCard.astro";
import { PROJECTS } from "@/constants/projects";
---

<section
  id="proyectos"
  class="container-page relative scroll-mt-16 py-16 md:py-24"
>
  <div
    class="glow-blob absolute top-24 -right-24 -z-1 h-80 w-80"
    aria-hidden="true"
  >
  </div>
  <h2
    data-reveal="left"
    class="font-martian-mono text-theme-800 text-3xl font-semibold md:text-4xl"
  >
    Mis Proyectos
  </h2>
  <div
    data-reveal="bar"
    style="transition-delay: 150ms"
    class="bg-theme-400 mt-2 mb-10 h-1 w-16 rounded-sm"
    aria-hidden="true"
  >
  </div>

  <!-- Desktop: featured full width, then two side by side -->
  <div class="flex flex-col gap-6">
    <!-- Featured card — full width; a big element rotating by the same
         degrees as a small one reads as way more motion, so it gets a much
         gentler tilt. -->
    <div data-reveal style="transition-delay: 120ms">
      <ProjectCard project={PROJECTS[0]} slideCount={4} tiltMax={1.2} />
    </div>

    <!-- Two smaller cards side by side -->
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      <div data-reveal style="transition-delay: 200ms">
        <ProjectCard project={PROJECTS[1]} slideCount={2} />
      </div>
      <div data-reveal style="transition-delay: 280ms">
        <ProjectCard project={PROJECTS[2]} slideCount={2} />
      </div>
    </div>
  </div>
</section>

<script>
  import { attachTilt } from "@/lib/tilt";

  document.querySelectorAll<HTMLElement>("[data-tilt]").forEach((el) => {
    const maxTilt = Number(el.dataset.tiltMax) || 2.5;
    attachTilt(el, { mode: "hover", maxTilt, peak: 550, lerp: 0.12 });
  });
</script>
