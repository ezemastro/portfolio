---
import ProjectCard from "@/components/ProjectCard.astro";
import { PROJECTS } from "@/constants/projects";
---

<section class="px-4 py-16 md:px-8">
  <div class="mx-auto max-w-6xl">
    <h2
      class="font-martian-mono text-theme-800 text-3xl font-semibold md:text-4xl"
    >
      Mis Proyectos
    </h2>
    <div
      class="bg-theme-400 mt-2 mb-10 h-1 w-16 rounded-full"
      aria-hidden="true"
    >
    </div>

    <!-- Desktop: featured full width, then two side by side -->
    <div class="flex flex-col gap-6">
      <!-- Featured card — full width -->
      <ProjectCard project={PROJECTS[0]} slideCount={4} />

      <!-- Two smaller cards side by side -->
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <ProjectCard project={PROJECTS[1]} slideCount={2} />
        <ProjectCard project={PROJECTS[2]} slideCount={2} />
      </div>
    </div>
  </div>
</section>
