---
import { TECH_STACK } from "@/constants/techStack";
import TechBadge from "@/components/TechBadge";

const PARAGRAPHS = [
  "Soy Ezequiel Mastropietro, desarrollador full stack argentino. Construyo aplicaciones web de alto rendimiento, apps móviles publicadas en Play Store y plataformas full-stack para gestión de equipos.",
  "Creo en entender los fundamentos antes que los frameworks: prefiero herramientas simples y bien documentadas antes que stacks complejos con mucha magia. Antes de escribir código pienso en la arquitectura — componentes, flujo de datos, manejo de errores — y mantengo un pipeline de CI/CD para iterar rápido con confianza.",
  "Cuando encuentro un problema nuevo, prefiero leer la documentación oficial antes que seguir tutoriales: entender el \"por qué\" de una tecnología vale más que memorizar su API.",
];
---

<section
  id="sobre-mi"
  class="container-page relative scroll-mt-16 py-16 md:py-24"
>
  <div
    class="glow-blob absolute bottom-0 -left-32 -z-1 h-96 w-96"
    aria-hidden="true"
  >
  </div>
  <h2
    data-reveal="left"
    class="font-martian-mono text-theme-800 text-3xl font-semibold md:text-4xl"
  >
    Sobre mí
  </h2>
  <div
    data-reveal="bar"
    style="transition-delay: 150ms"
    class="bg-theme-400 mt-2 mb-10 h-1 w-16 rounded-sm"
    aria-hidden="true"
  >
  </div>

  <div class="grid grid-cols-1 gap-8 md:grid-cols-5">
    <!-- Terminal-style bio panel -->
    <div
      data-reveal="scale"
      style="transition-delay: 120ms"
      class="bg-theme-800 border-theme-700 flex flex-col rounded-sm border md:col-span-3"
    >
      <div class="bg-theme-700 flex h-9 w-full items-center rounded-t-sm px-3">
        <div class="flex gap-1.5" aria-hidden="true">
          <span class="bg-theme-500 size-2.5 rounded-full"></span>
          <span class="bg-theme-500 size-2.5 rounded-full"></span>
          <span class="bg-theme-500 size-2.5 rounded-full"></span>
        </div>
        <p class="text-theme-100 font-martian-mono ml-3 text-xs font-light">
          ~/sobre-mi.md
        </p>
      </div>
      <div class="flex flex-col gap-4 p-6">
        {
          PARAGRAPHS.map((paragraph) => (
            <p class="text-theme-100 font-martian-mono text-sm leading-relaxed">
              {paragraph}
            </p>
          ))
        }
      </div>
    </div>

    <!-- Stack -->
    <div
      data-reveal
      style="transition-delay: 200ms"
      class="border-theme-200 flex flex-col rounded-sm border p-6 md:col-span-2"
    >
      <p
        class="text-theme-500 font-martian-mono mb-4 text-xs font-medium tracking-widest uppercase"
      >
        Stack
      </p>
      <div class="flex flex-wrap gap-2">
        {
          TECH_STACK.map((tech, i) => (
            <div data-reveal style={`transition-delay: ${250 + i * 35}ms`}>
              <TechBadge
                name={tech.name}
                icon={tech.icon}
                explanation={tech.description}
                iconOnly
                client:load
              />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
